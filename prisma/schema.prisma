generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  THERAPIST
  ADMIN
}

enum TherapistApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum BookingStatus {
  PENDING_THERAPIST
  CONFIRMED
  REJECTED
  CANCELLED
  AUTO_CANCELLED
  COMPLETED
}

enum SessionStatus {
  SCHEDULED
  CANCELLED
  DONE
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id                    String               @id @default(cuid())
  email                 String               @unique
  passwordHash          String
  firstName             String?
  lastName              String?
  role                  UserRole
  isActive              Boolean              @default(true)
  clientProfile         ClientProfile?
  therapistProfile      TherapistProfile?
  clientBookings        Booking[]            @relation("ClientBookings")
  therapistBookings     Booking[]            @relation("TherapistBookings")
  cancelledBookings     Booking[]            @relation("CancelledBookings")
  emailLogs             EmailLog[]
  auditLogs             AuditLog[]           @relation("ActorAuditLogs")
  passwordResetTokens   PasswordResetToken[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([role])
  @@index([isActive])
  @@index([role, isActive])
}

model ClientProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([createdAt])
}

model TherapistProfile {
  id                    String                   @id @default(cuid())
  userId                String                   @unique
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName           String?
  bio                   String?
  specialization        String?
  approvalStatus        TherapistApprovalStatus  @default(PENDING)
  isApproved            Boolean                  @default(false)
  googleCalendarId      String?                  @unique
  googleCalendarEmail   String?                  @unique
  payoutDetails         TherapistPayoutDetails?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([approvalStatus])
  @@index([isApproved])
  @@index([createdAt])
  @@index([approvalStatus, isApproved])
}

model Booking {
  id                 String        @id @default(cuid())
  clientId           String
  therapistId        String
  startsAt           DateTime
  endsAt             DateTime
  bookingStatus      BookingStatus @default(PENDING_THERAPIST)
  notes              String?
  cancelledAt        DateTime?
  cancelledByUserId  String?
  session            Session?
  payment            Payment?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  client             User          @relation("ClientBookings", fields: [clientId], references: [id], onDelete: Restrict)
  therapist          User          @relation("TherapistBookings", fields: [therapistId], references: [id], onDelete: Restrict)
  cancelledBy        User?         @relation("CancelledBookings", fields: [cancelledByUserId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([therapistId])
  @@index([startsAt])
  @@index([endsAt])
  @@index([bookingStatus])
  @@index([cancelledByUserId])
  @@index([clientId, startsAt])
  @@index([therapistId, startsAt])
  @@index([bookingStatus, startsAt])
  @@index([therapistId, bookingStatus])
}

model Session {
  id             String        @id @default(cuid())
  bookingId      String        @unique
  sessionStatus  SessionStatus @default(SCHEDULED)
  meetingUrl     String?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  booking        Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([sessionStatus])
  @@index([createdAt])
  @@index([completedAt])
  @@index([sessionStatus, createdAt])
}

model Payment {
  id                      String        @id @default(cuid())
  bookingId               String        @unique
  stripeCheckoutSessionId String?       @unique
  stripePaymentIntentId   String?       @unique
  amount                  Int
  currency                String        @default("usd")
  paymentStatus           PaymentStatus @default(UNPAID)
  paidAt                  DateTime?
  failedAt                DateTime?
  refundedAt              DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  booking                 Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([paymentStatus])
  @@index([createdAt])
  @@index([currency])
  @@index([paidAt])
  @@index([failedAt])
  @@index([refundedAt])
  @@index([paymentStatus, createdAt])
}

model TherapistPayoutDetails {
  id                   String            @id @default(cuid())
  therapistProfileId   String            @unique
  accountHolderName    String
  bankName             String?
  iban                 String?
  swift                String?
  country              String?
  isVerified           Boolean           @default(false)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  therapistProfile     TherapistProfile  @relation(fields: [therapistProfileId], references: [id], onDelete: Cascade)

  @@index([isVerified])
  @@index([country])
  @@index([createdAt])
  @@index([isVerified, country])
}

model EmailLog {
  id            String      @id @default(cuid())
  userId        String?
  email         String
  template      String
  subject       String
  status        EmailStatus @default(PENDING)
  sentAt        DateTime?
  failedAt      DateTime?
  errorMessage  String?
  createdAt     DateTime    @default(now())
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([template])
  @@index([status])
  @@index([createdAt])
  @@index([email, status])
  @@index([template, createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  entityType   String
  entityId     String
  action       String
  before       Json?
  after        Json?
  createdAt    DateTime @default(now())
  actorUser    User?    @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@index([userId, expiresAt])
}