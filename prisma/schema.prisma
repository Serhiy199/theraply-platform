generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  THERAPIST
  ADMIN
}

enum TherapistApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum BookingStatus {
  PENDING_THERAPIST
  CONFIRMED
  REJECTED
  CANCELLED
  AUTO_CANCELLED
  COMPLETED
}

enum SessionStatus {
  SCHEDULED
  CANCELLED
  DONE
}

model User {
  id                    String            @id @default(cuid())
  email                 String            @unique
  passwordHash          String
  firstName             String?
  lastName              String?
  role                  UserRole
  isActive              Boolean           @default(true)
  clientProfile         ClientProfile?
  therapistProfile      TherapistProfile?
  clientBookings        Booking[]         @relation("ClientBookings")
  therapistBookings     Booking[]         @relation("TherapistBookings")
  cancelledBookings     Booking[]         @relation("CancelledBookings")
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([role])
  @@index([isActive])
}

model ClientProfile {
  id         String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
}

model TherapistProfile {
  id                String                    @id @default(cuid())
  userId            String                    @unique
  user              User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName       String?
  bio               String?
  specialization    String?
  approvalStatus    TherapistApprovalStatus   @default(PENDING)
  isApproved        Boolean                   @default(false)
  calendlyLink      String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([approvalStatus])
  @@index([isApproved])
  @@index([createdAt])
}

model Booking {
  id                 String        @id @default(cuid())
  clientId           String
  therapistId        String
  startsAt           DateTime
  endsAt             DateTime
  bookingStatus      BookingStatus @default(PENDING_THERAPIST)
  notes              String?
  cancelledAt        DateTime?
  cancelledByUserId  String?
  session            Session?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  client             User          @relation("ClientBookings", fields: [clientId], references: [id], onDelete: Restrict)
  therapist          User          @relation("TherapistBookings", fields: [therapistId], references: [id], onDelete: Restrict)
  cancelledBy        User?         @relation("CancelledBookings", fields: [cancelledByUserId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([therapistId])
  @@index([startsAt])
  @@index([bookingStatus])
  @@index([cancelledByUserId])
}

model Session {
  id             String        @id @default(cuid())
  bookingId      String        @unique
  sessionStatus  SessionStatus @default(SCHEDULED)
  meetingUrl     String?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  booking        Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([sessionStatus])
  @@index([createdAt])
}